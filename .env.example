# Supabase (получить на app.supabase.com → Project Settings → API)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Anthropic Claude API (получить на console.anthropic.com)
# Без ключа — приложение работает с заготовленными ответами (demo mode)
VITE_ANTHROPIC_API_KEY=sk-ant-...

# VK API Token (для загрузки новостей из группы vk.com/bbplay__tmb)
# Получить: vk.com/dev → Мои приложения → создать Standalone-приложение → Сервисный ключ
# Без токена — показываются демо-новости
VITE_VK_TOKEN=
